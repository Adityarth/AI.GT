//////////////////////////////////////////////////////////////
// CONFIG
//////////////////////////////////////////////////////////////

const int INPUT_W = 640;
const int INPUT_H = 640;

const int NUM_CLASSES = 80;
const int NUM_BOXES = 8400;

//////////////////////////////////////////////////////////////
// CLASSES
//////////////////////////////////////////////////////////////

unordered_map<int, string> classNames =
{
    {0, "person"},
    {1, "bicycle"},
    {2, "car"},
    {3, "motorcycle"},
    {5, "bus"},
    {7, "truck"}
};

//////////////////////////////////////////////////////////////
// THREAD SAFE QUEUE
//////////////////////////////////////////////////////////////

template<typename T>
class SafeQueue
{
private:

    queue<T> q;

    mutex m;

    condition_variable cv;

public:

    void push(const T& item)
    {
        unique_lock<mutex> lock(m);

        q.push(item);

        cv.notify_one();
    }

    T pop()
    {
        unique_lock<mutex> lock(m);

        cv.wait(lock, [this]
            {
                return !q.empty();
            });

        T item = q.front();

        q.pop();

        return item;
    }
};

//////////////////////////////////////////////////////////////
// TRACK
//////////////////////////////////////////////////////////////

struct Track
{
    int id = -1;

    int class_id = -1;

    Rect box;

    Point center;

    bool counted = false;
};

//////////////////////////////////////////////////////////////
// DETECTION RESULT
//////////////////////////////////////////////////////////////

struct DetectionResult
{
    Mat frame;

    vector<Rect> boxes;

    vector<int> class_ids;

    vector<float> confidences;
};

//////////////////////////////////////////////////////////////
// GLOBALS
//////////////////////////////////////////////////////////////

SafeQueue<Mat> frameQueue;

SafeQueue<DetectionResult> detectionQueue;

atomic<bool> running(true);

//////////////////////////////////////////////////////////////
// IOU
//////////////////////////////////////////////////////////////

float computeIOU( const Rect& a, const Rect& b)
{
    int x1 = max(a.x, b.x);

    int y1 = max(a.y, b.y);

    int x2 = min(a.x + a.width, b.x + b.width);

    int y2 = min(a.y + a.height, b.y + b.height);

    int inter = max(0, x2 - x1) * max(0, y2 - y1);

    int unionArea = a.area() + b.area() - inter;

    if (unionArea <= 0)
        return 0.0f;

    return (float)inter / unionArea;
}

//////////////////////////////////////////////////////////////
// LOAD ENGINE
//////////////////////////////////////////////////////////////

vector<char> loadEngine( const string& filename)
{
    ifstream file( filename, ios::binary);

    file.seekg(0, ios::end);

    size_t size = file.tellg();

    file.seekg(0, ios::beg);

    vector<char> buffer(size);

    file.read(buffer.data(), size);

    return buffer;
}

//////////////////////////////////////////////////////////////
// CAPTURE THREAD
//////////////////////////////////////////////////////////////

void captureThread( VideoCapture& cap)
{
    while (running)
    {
        Mat frame;

        cap >> frame;

        if (frame.empty())
        {
            running = false;

            break;
        }

        frameQueue.push(frame);
    }
}

//////////////////////////////////////////////////////////////
// GPU INFERENCE THREAD
//////////////////////////////////////////////////////////////

void inferenceThread( IExecutionContext* context, void** bindings, float* cpuOutput, float* gpuInput, float* gpuOutput, cudaStream_t stream)
{
    cuda::GpuMat gpuFrame;
    cuda::GpuMat gpuResized;
    cuda::GpuMat gpuRGB;
    cuda::GpuMat gpuFloat;

    while (running)
    {
        Mat frame = frameQueue.pop();

        if (frame.empty())
            continue;

        ////////////////////////////////////////////////
        // GPU UPLOAD
        ////////////////////////////////////////////////

        gpuFrame.upload(frame);

        ////////////////////////////////////////////////
        // GPU RESIZE
        ////////////////////////////////////////////////

        cuda::resize( gpuFrame, gpuResized, Size(INPUT_W, INPUT_H));

        ////////////////////////////////////////////////
        // GPU COLOR
        ////////////////////////////////////////////////

        cuda::cvtColor( gpuResized, gpuRGB, COLOR_BGR2RGB);

        ////////////////////////////////////////////////
        // FLOAT
        ////////////////////////////////////////////////

        gpuRGB.convertTo( gpuFloat, CV_32F, 1.0 / 255.0);

        ////////////////////////////////////////////////
        // DOWNLOAD TEMP
        ////////////////////////////////////////////////

        Mat tempCPU;

        gpuFloat.download(tempCPU);

        ////////////////////////////////////////////////
        // SPLIT
        ////////////////////////////////////////////////

        vector<Mat> channels;

        split(tempCPU, channels);

        ////////////////////////////////////////////////
        // COPY TO GPU
        ////////////////////////////////////////////////

        size_t channelSize = INPUT_W * INPUT_H * sizeof(float);

        cudaMemcpyAsync( gpuInput, channels[0].ptr<float>(), channelSize, cudaMemcpyHostToDevice, stream);

        cudaMemcpyAsync( gpuInput + INPUT_W * INPUT_H, channels[1].ptr<float>(), channelSize, cudaMemcpyHostToDevice, stream);

        cudaMemcpyAsync( gpuInput + 2 * INPUT_W * INPUT_H, channels[2].ptr<float>(), channelSize, cudaMemcpyHostToDevice, stream);

        ////////////////////////////////////////////////
        // INFERENCE
        ////////////////////////////////////////////////

        context->enqueueV2( bindings, stream, nullptr);

        ////////////////////////////////////////////////
        // OUTPUT
        ////////////////////////////////////////////////
        
        cudaMemcpyAsync( cpuOutput, gpuOutput, 84 * NUM_BOXES * sizeof(float), cudaMemcpyDeviceToHost, stream);

        cudaStreamSynchronize(stream);

        ////////////////////////////////////////////////
        // PARSE
        ////////////////////////////////////////////////

        vector<Rect> boxes;
        vector<int> class_ids;
        vector<float> confidences;

        for (int i = 0; i < NUM_BOXES; i++)
        {
            float cx = cpuOutput[0 * NUM_BOXES + i];

            float cy = cpuOutput[1 * NUM_BOXES + i];

            float w = cpuOutput[2 * NUM_BOXES + i];
            
            float h = cpuOutput[3 * NUM_BOXES + i];

            int class_id = -1;

            float maxScore = 0.0f;

            for (int c = 0; c < NUM_CLASSES; c++)
            {
                float score = cpuOutput[(4 + c) * NUM_BOXES + i];

                if (score > maxScore)
                {
                    maxScore = score;

                    class_id = c;
                }
            }

            if (maxScore < 0.4f)
                continue;

            if (classNames.find(class_id) == classNames.end())
            {
                continue;
            }

            int left = static_cast<int>( (cx - 0.5f * w) * frame.cols / INPUT_W);

            int top = static_cast<int>( (cy - 0.5f * h) * frame.rows / INPUT_H);

            int width = static_cast<int>( w * frame.cols / INPUT_W);

            int height = static_cast<int>( h * frame.rows / INPUT_H);

            boxes.push_back( Rect(left, top, width, height));

            confidences.push_back(maxScore);

            class_ids.push_back(class_id);
        }

        ////////////////////////////////////////////////
        // NMS
        ////////////////////////////////////////////////

        vector<int> indices;

        dnn::NMSBoxes( boxes, confidences, 0.4f, 0.5f, indices);

        DetectionResult result;

        result.frame = frame;

        for (int idx : indices)
        {
            result.boxes.push_back(boxes[idx]);

            result.class_ids.push_back(class_ids[idx]);

            result.confidences.push_back(confidences[idx]);
        }

        detectionQueue.push(result);
    }
}

//////////////////////////////////////////////////////////////
// DISPLAY THREAD
//////////////////////////////////////////////////////////////

void displayThread( VideoWriter& writer, int frameHeight)
{
    vector<Track> tracks;

    int nextTrackID = 0;

    int totalCount = 0;

    int lineY = frameHeight / 2;

    while (running)
    {
        DetectionResult result = detectionQueue.pop();

        Mat frame = result.frame;

        ////////////////////////////////////////////////
        // FPS
        ////////////////////////////////////////////////

        static double fps = 0.0;

        static int64 prev = getTickCount();

        int64 now = getTickCount();

        fps = getTickFrequency() / (now - prev);

        prev = now;

        ////////////////////////////////////////////////
        // TRACKING
        ////////////////////////////////////////////////

        vector<Track> updatedTracks;

        for (size_t i = 0; i < result.boxes.size(); i++)
        {
            Rect box = result.boxes[i];

            Point center( box.x + box.width / 2, box.y + box.height / 2);

            bool matched = false;

            for (auto& track : tracks)
            {
                float iou = computeIOU( box, track.box);

                if (iou > 0.3f)
                {
                    track.box = box;

                    track.center = center;

                    track.class_id = result.class_ids[i];

                    if (!track.counted && center.y >= lineY - 5 && center.y <= lineY + 5)
                    {
                        track.counted = true;

                        totalCount++;
                    }

                    updatedTracks.push_back(track);

                    matched = true;

                    break;
                }
            }

            if (!matched)
            {
                Track t;

                t.id = nextTrackID++;

                t.box = box;

                t.center = center;

                t.class_id = result.class_ids[i];

                updatedTracks.push_back(t);
            }
        }

        tracks = updatedTracks;

        ////////////////////////////////////////////////
        // DRAW
        ////////////////////////////////////////////////

        line( frame, Point(0, lineY), Point(frame.cols, lineY), Scalar(255, 0, 255), 2);

        for (auto& track : tracks)
        {
            rectangle( frame, track.box, Scalar(0, 255, 0), 2);

            circle( frame, track.center, 4, Scalar(0, 0, 255), -1);

            string label = classNames[track.class_id] + " ID:" + to_string(track.id);

            putText( frame, label, Point(track.box.x,track.box.y - 10),FONT_HERSHEY_SIMPLEX, 0.6, Scalar(0, 255, 255), 2);
        }

        ////////////////////////////////////////////////
        // FPS TEXT
        ////////////////////////////////////////////////

        putText( frame, "FPS: " + to_string((int)fps), Point(20, 40), FONT_HERSHEY_SIMPLEX, 1.0, Scalar(255, 0, 0), 2);

        ////////////////////////////////////////////////
        // COUNT
        ////////////////////////////////////////////////

        putText( frame, "Total Count: " + to_string(totalCount), Point(20, 80), FONT_HERSHEY_SIMPLEX, 1.0, Scalar(0, 0, 255), 2);

        ////////////////////////////////////////////////
        // SHOW
        ////////////////////////////////////////////////

        imshow( "AI Traffic System", frame);

        writer.write(frame);

        if (waitKey(1) == 27)
        {
            running = false;

            break;
        }


    }
}

//////////////////////////////////////////////////////////////
// MAIN
//////////////////////////////////////////////////////////////

int main()
{
    //////////////////////////////////////////////////////////
    // LOAD ENGINE
    //////////////////////////////////////////////////////////

    vector<char> engineData = loadEngine("yolov8s.engine");

    IRuntime* runtime = createInferRuntime(logger);

    ICudaEngine* engine = runtime->deserializeCudaEngine( engineData.data(), engineData.size());

    IExecutionContext* context = engine->createExecutionContext();

    //////////////////////////////////////////////////////////
    // STREAM
    //////////////////////////////////////////////////////////

    cudaStream_t stream;

    cudaStreamCreate(&stream);

    //////////////////////////////////////////////////////////
    // MEMORY
    //////////////////////////////////////////////////////////

    float* gpuInput = nullptr;

    float* gpuOutput = nullptr;

    float* cpuOutput = nullptr;

    cudaMalloc( (void**)&gpuInput, 3 * INPUT_W * INPUT_H * sizeof(float));

    cudaMalloc( (void**)&gpuOutput, 84 * NUM_BOXES * sizeof(float));

    cudaMallocHost( (void**)&cpuOutput, 84 * NUM_BOXES * sizeof(float));

    //////////////////////////////////////////////////////////
    // BINDINGS
    //////////////////////////////////////////////////////////

    int inputIndex = engine->getBindingIndex("images");

    int outputIndex = engine->getBindingIndex("output0");

    void* bindings[2];

    bindings[inputIndex] = gpuInput;

    bindings[outputIndex] = gpuOutput;

    //////////////////////////////////////////////////////////
    // VIDEO
    //////////////////////////////////////////////////////////

    VideoCapture cap("Traffic4.mp4");

    if (!cap.isOpened())
    {
        cout << "Cannot open video!" << endl;

        return -1;
    }

    int width = static_cast<int>( cap.get(CAP_PROP_FRAME_WIDTH));

    int height = static_cast<int>( cap.get(CAP_PROP_FRAME_HEIGHT));

    double fps = cap.get(CAP_PROP_FPS);

    //////////////////////////////////////////////////////////
    // WRITER
    //////////////////////////////////////////////////////////
    
    VideoWriter writer( "output4.mp4", VideoWriter::fourcc( 'M', 'P', '4', 'V'), fps, Size(width, height));

    //////////////////////////////////////////////////////////
    // THREADS
    //////////////////////////////////////////////////////////

    thread t1( captureThread, ref(cap));

    thread t2( inferenceThread, context, bindings, cpuOutput, gpuInput, gpuOutput, stream);

    thread t3( displayThread, ref(writer), height);

    //////////////////////////////////////////////////////////
    // JOIN
    //////////////////////////////////////////////////////////

    t1.join();

    t2.join();

    t3.join();

    //////////////////////////////////////////////////////////
    // CLEANUP
    //////////////////////////////////////////////////////////

    writer.release();
    cap.release();
    cudaFree(gpuInput);
    cudaFree(gpuOutput);
    cudaFreeHost(cpuOutput);
    cudaStreamDestroy(stream);
    context->destroy();
    engine->destroy();
    runtime->destroy();
    destroyAllWindows();

    return 0;
}
